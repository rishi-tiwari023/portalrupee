<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Account Statement - PortalRupee</title>
  <style>
    body { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; color: #333; margin: 0; padding: 20px; }
    .header { text-align: center; border-bottom: 2px solid #0056b3; padding-bottom: 20px; margin-bottom: 20px; }
    .header h1 { color: #0056b3; margin: 0; font-size: 28px; }
    .header h2 { color: #555; margin: 10px 0 5px; font-size: 20px; }
    .header p { color: #777; margin: 0; font-size: 14px; }
    .info-section { display: flex; margin-bottom: 30px; }
    .info-box { width: 50%; padding-right: 20px; }
    .info-box h3 { border-bottom: 1px solid #eee; padding-bottom: 5px; margin-bottom: 10px; color: #444; font-size: 16px; }
    .info-box p { margin: 5px 0; font-size: 14px; }
    table { width: 100%; border-collapse: collapse; margin-top: 20px; font-size: 14px; }
    th, td { border: 1px solid #ddd; padding: 10px; text-align: left; }
    th { background-color: #f8f9fa; font-weight: bold; color: #333; }
    .text-right { text-align: right; }
    .credit { color: green; }
    .debit { color: red; }
    .footer { margin-top: 40px; text-align: center; font-size: 12px; color: #777; border-top: 1px solid #eee; padding-top: 20px; }
  </style>
</head>
<body>
  <div class="header">
    <h1>PortalRupee</h1>
    <h2>Account Statement</h2>
    <p>Period: <%= startDate %> to <%= endDate %></p>
  </div>

  <div class="info-section">
    <div class="info-box">
      <h3>Customer Details</h3>
      <p><strong>Name:</strong> <%= user.firstName %> <%= user.lastName %></p>
      <p><strong>Email:</strong> <%= user.email %></p>
      <p><strong>Mobile:</strong> <%= user.mobile %></p>
    </div>
    <div class="info-box">
      <h3>Account Details</h3>
      <p><strong>Account Number:</strong> <%= account.accountNumber %></p>
      <p><strong>Account Type:</strong> <%= account.accountType %></p>
      <p><strong>Current Balance:</strong> ₹<%= account.balance.toFixed(2) %></p>
    </div>
  </div>

  <h3>Transaction History</h3>
  <table>
    <thead>
      <tr>
        <th>Date</th>
        <th>Transaction ID</th>
        <th>Description</th>
        <th>Type</th>
        <th class="text-right">Amount (₹)</th>
      </tr>
    </thead>
    <tbody>
      <% if (transactions.length > 0) { %>
        <% transactions.forEach(function(txn) { %>
          <tr>
            <td><%= txn.date %></td>
            <td><%= txn.id %></td>
            <td><%= txn.description %></td>
            <td><%= txn.type %></td>
            <td class="text-right <%= txn.isCredit ? 'credit' : 'debit' %>">
              <%= txn.isCredit ? '+' : '-' %><%= txn.amount.toFixed(2) %>
            </td>
          </tr>
        <% }); %>
      <% } else { %>
        <tr>
          <td colspan="5" style="text-align: center;">No transactions found for this period.</td>
        </tr>
      <% } %>
    </tbody>
  </table>

  <div class="footer">
    <p>This is a computer-generated statement and does not require a signature.</p>
    <p>&copy; <%= new Date().getFullYear() %> PortalRupee. All rights reserved.</p>
  </div>
</body>
</html>
